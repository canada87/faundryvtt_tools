<div class="encounter-generator-content">

  {{#if hasCompendium}}

    {{#if hasTypes}}
      <div class="form-group">
        <label><strong>{{localize "ENCOUNTERS.FilterTypes"}}</strong></label>
        <small class="filter-hint">{{localize "ENCOUNTERS.FilterHint"}}</small>
        <div class="type-tags">
          {{#each types}}
            <div class="type-tag" data-type="{{this}}">{{this}}</div>
          {{/each}}
        </div>
      </div>
      <hr>
    {{/if}}

    {{#each groups}}
      <div class="form-group group-input">
        <label><strong>{{this.label}}</strong></label>
        <input type="number" data-group-index="{{@index}}" value="0" min="0" />
      </div>
    {{/each}}

    <div class="generator-footer">
      <button type="button" data-action="generate" class="generate-btn">
        <i class="fas fa-dice-d20"></i> {{localize "ENCOUNTERS.Generate"}}
      </button>
    </div>

  {{else}}
    <div class="empty-state">
      <i class="fas fa-exclamation-triangle"></i>
      <p>{{localize "ENCOUNTERS.Warn.NoCompendium"}}</p>
    </div>
  {{/if}}

</div>
