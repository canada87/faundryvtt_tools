<div class="encounter-generator-content">

  {{#if hasCompendium}}

    <!-- ========== Random scenario ========== -->
    <div class="scenario-section">
      <button type="button" data-action="randomScenario" class="scenario-btn">
        <i class="fas fa-theater-masks"></i> {{localize "ENCOUNTERS.RandomScenario"}}
      </button>
      <div class="scenario-result" id="scenario-result">
        <span class="scenario-placeholder">{{localize "ENCOUNTERS.ScenarioNone"}}</span>
      </div>
    </div>

    <hr>

    <!-- ========== Mode toggle ========== -->
    <div class="mode-toggle">
      <button type="button" class="mode-btn active" data-mode="difficulty">
        <i class="fas fa-balance-scale"></i> {{localize "ENCOUNTERS.DifficultyMode"}}
      </button>
      <button type="button" class="mode-btn" data-mode="manual">
        <i class="fas fa-sliders-h"></i> {{localize "ENCOUNTERS.ManualMode"}}
      </button>
    </div>

    <!-- ========== Difficulty mode ========== -->
    <div class="mode-section difficulty-section">

      <div class="difficulty-inputs">
        <div class="form-group">
          <label>{{localize "ENCOUNTERS.PartyLevel"}}</label>
          <input type="number" id="party-level" value="1" min="1" />
        </div>
        <div class="form-group">
          <label>{{localize "ENCOUNTERS.PartySize"}}</label>
          <input type="number" id="party-size" value="4" min="1" />
        </div>
        <div class="form-group">
          <label>{{localize "ENCOUNTERS.Difficulty"}}</label>
          <select id="difficulty">
            <option value="1">{{localize "ENCOUNTERS.DiffVeryLow"}}</option>
            <option value="2">{{localize "ENCOUNTERS.DiffLow"}}</option>
            <option value="3">{{localize "ENCOUNTERS.DiffMedium"}}</option>
            <option value="4" selected>{{localize "ENCOUNTERS.DiffHigh"}}</option>
            <option value="5">{{localize "ENCOUNTERS.DiffVeryHigh"}}</option>
          </select>
        </div>
      </div>

      <div class="budget-summary" id="budget-summary"></div>
    </div>

    <!-- ========== Manual mode (hidden) ========== -->
    <div class="mode-section manual-section" style="display: none;">
      {{#each groups}}
        <div class="form-group group-input">
          <label><strong>{{this.label}}</strong> <small>(Lv {{this.minLevel}}–{{this.maxLevel}})</small></label>
          <input type="number" data-group-index="{{@index}}" value="0" min="0" />
        </div>
      {{/each}}
    </div>

    <!-- ========== Type filter (shared) ========== -->
    {{#if hasTypes}}
      <hr>
      <div class="form-group">
        <label><strong>{{localize "ENCOUNTERS.FilterTypes"}}</strong></label>
        <small class="filter-hint">{{localize "ENCOUNTERS.FilterHint"}}</small>
        <div class="type-tags">
          {{#each types}}
            <div class="type-tag" data-type="{{this}}">{{this}}</div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    <!-- ========== Generate ========== -->
    <div class="generator-footer">
      <button type="button" data-action="generate" class="generate-btn">
        <i class="fas fa-dice-d20"></i> {{localize "ENCOUNTERS.Generate"}}
      </button>
    </div>

  {{else}}
    <div class="empty-state">
      <i class="fas fa-exclamation-triangle"></i>
      <p>{{localize "ENCOUNTERS.Warn.NoCompendium"}}</p>
    </div>
  {{/if}}

</div>
