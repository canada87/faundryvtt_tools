<div class="encounter-settings-content">

  <div class="form-group">
    <label>{{localize "ENCOUNTERS.CompendiumName"}}</label>
    <input type="text" name="compendium" value="{{compendium}}"
           placeholder="module.Compendium" />
    <small class="hint">{{localize "ENCOUNTERS.CompendiumHint"}}</small>
  </div>

  <div class="form-group">
    <label>{{localize "ENCOUNTERS.CreatureTypePath"}}</label>
    <input type="text" name="creatureTypePath" value="{{creatureTypePath}}"
           placeholder="system.details.creatureType" />
    <small class="hint">{{localize "ENCOUNTERS.CreatureTypePathHint"}}</small>
  </div>

  <div class="form-group">
    <label>{{localize "ENCOUNTERS.LevelPath"}}</label>
    <input type="text" name="levelPath" value="{{levelPath}}"
           placeholder="system.details.level" />
    <small class="hint">{{localize "ENCOUNTERS.LevelPathHint"}}</small>
  </div>

  <div class="form-group">
    <label>{{localize "ENCOUNTERS.TargetFolder"}}</label>
    <input type="text" name="targetFolder" value="{{targetFolder}}"
           placeholder="mostri" />
    <small class="hint">{{localize "ENCOUNTERS.TargetFolderHint"}}</small>
  </div>

  <hr>

  <div class="groups-section">
    <div class="groups-header">
      <label><strong>{{localize "ENCOUNTERS.Groups"}}</strong></label>
      <button type="button" data-action="addGroup" class="add-group-btn">
        <i class="fas fa-plus"></i> {{localize "ENCOUNTERS.AddGroup"}}
      </button>
    </div>

    <div class="groups-table-header">
      <span class="col-label">{{localize "ENCOUNTERS.GroupLabel"}}</span>
      <span class="col-level">{{localize "ENCOUNTERS.GroupMinLevel"}}</span>
      <span class="col-level">{{localize "ENCOUNTERS.GroupMaxLevel"}}</span>
      <span class="col-action"></span>
    </div>

    {{#each groups}}
      <div class="group-entry" data-group-index="{{@index}}">
        <input type="text" name="groups.{{@index}}.label"
               value="{{this.label}}" placeholder="CR 1-2" class="col-label" />
        <input type="number" name="groups.{{@index}}.minLevel"
               value="{{this.minLevel}}" min="0" class="col-level" />
        <input type="number" name="groups.{{@index}}.maxLevel"
               value="{{this.maxLevel}}" min="0" class="col-level" />
        <button type="button" data-action="removeGroup" class="col-action"
                title="{{localize 'ENCOUNTERS.RemoveGroup'}}">
          <i class="fas fa-trash"></i>
        </button>
      </div>
    {{/each}}
  </div>

  <hr>

  <div class="difficulty-config-section">
    <div class="groups-header">
      <label><strong>{{localize "ENCOUNTERS.DifficultyConfig"}}</strong></label>
    </div>
    <small class="hint">{{localize "ENCOUNTERS.DifficultyConfigHint"}}</small>

    <div class="diff-config-grid">
      <div class="diff-config-header">
        <span class="col-diff-label">{{localize "ENCOUNTERS.Difficulty"}}</span>
        <span class="col-diff-mult">{{localize "ENCOUNTERS.BudgetMultiplier"}}</span>
      </div>
      <div class="diff-config-row">
        <label class="col-diff-label">{{localize "ENCOUNTERS.DiffVeryLow"}}</label>
        <input type="number" name="diffMult.veryLow" value="{{diffMult.veryLow}}"
               step="0.1" min="0.01" class="col-diff-mult" />
      </div>
      <div class="diff-config-row">
        <label class="col-diff-label">{{localize "ENCOUNTERS.DiffLow"}}</label>
        <input type="number" name="diffMult.low" value="{{diffMult.low}}"
               step="0.1" min="0.01" class="col-diff-mult" />
      </div>
      <div class="diff-config-row">
        <label class="col-diff-label">{{localize "ENCOUNTERS.DiffMedium"}}</label>
        <input type="number" name="diffMult.medium" value="{{diffMult.medium}}"
               step="0.1" min="0.01" class="col-diff-mult" />
      </div>
      <div class="diff-config-row">
        <label class="col-diff-label">{{localize "ENCOUNTERS.DiffHigh"}}</label>
        <input type="number" name="diffMult.high" value="{{diffMult.high}}"
               step="0.1" min="0.01" class="col-diff-mult" />
      </div>
      <div class="diff-config-row">
        <label class="col-diff-label">{{localize "ENCOUNTERS.DiffVeryHigh"}}</label>
        <input type="number" name="diffMult.veryHigh" value="{{diffMult.veryHigh}}"
               step="0.1" min="0.01" class="col-diff-mult" />
      </div>
    </div>

    <div class="form-group" style="margin-top: 8px;">
      <label>{{localize "ENCOUNTERS.LevelOffset"}}</label>
      <input type="number" name="levelOffset" value="{{levelOffset}}" step="1" />
      <small class="hint">{{localize "ENCOUNTERS.LevelOffsetHint"}}</small>
    </div>
  </div>

  <hr>

  <div class="scenarios-section">
    <div class="scenarios-header">
      <label><strong>{{localize "ENCOUNTERS.Scenarios"}}</strong></label>
      <button type="button" data-action="addScenario" class="add-scenario-btn">
        <i class="fas fa-plus"></i> {{localize "ENCOUNTERS.AddScenario"}}
      </button>
    </div>
    <small class="hint">{{localize "ENCOUNTERS.ScenariosHint"}}</small>

    <div class="scenarios-list">
      {{#each scenarios}}
        <div class="scenario-entry" data-scenario-index="{{@index}}">
          <textarea name="scenarios.{{@index}}" rows="2">{{this}}</textarea>
          <button type="button" data-action="removeScenario"
                  title="{{localize 'ENCOUNTERS.RemoveScenario'}}">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      {{/each}}
    </div>
  </div>

  <button type="submit" class="submit-btn">
    <i class="fas fa-save"></i> {{localize "ENCOUNTERS.Save"}}
  </button>

</div>
