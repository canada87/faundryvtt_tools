<div class="hexmap-settings-content">

  <section class="hexmap-section">
    <h3>{{localize "HEXMAP.TerrainFolders"}}</h3>
    <p class="hint">{{localize "HEXMAP.TerrainFoldersHint"}}</p>
    <div class="hexmap-terrain-list">
      {{#each terrainTypes}}
        <div class="hexmap-terrain-row">
          <label>{{label}}</label>
          <input type="text" data-terrain-id="{{id}}" value="{{folder}}"
                 placeholder="modules/my-tiles/{{id}}" />
        </div>
      {{/each}}
    </div>
  </section>

  <section class="hexmap-section">
    <h3>{{localize "HEXMAP.PoiFolder"}}</h3>
    <p class="hint">{{localize "HEXMAP.PoiFolderHint"}}</p>
    <input type="text" data-field="poiFolder" value="{{poiFolder}}"
           placeholder="modules/my-tiles/points_of_interest"
           class="hexmap-full-input" />
  </section>

  <div class="hexmap-footer">
    <button type="button" data-action="save" class="hexmap-btn-primary">
      <i class="fas fa-save"></i> {{localize "HEXMAP.Save"}}
    </button>
  </div>

</div>
